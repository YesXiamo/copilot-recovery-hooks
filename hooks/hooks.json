{
  "version": 1,
  "hooks": {
    "sessionStart": [
      { "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-resume.sh" }
    ],
    "sessionEnd": [
      { "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-finalize.sh" }
    ],
    "beforeSubmitPrompt": [
      { "command": "${CLAUDE_PLUGIN_ROOT}/hooks/budget-guard.sh", "failClosed": true }
    ],
    "preToolUse": [
      {
        "command": "${CLAUDE_PLUGIN_ROOT}/hooks/tool-guard.sh",
        "matcher": "Shell|Read|Write|Edit|Grep",
        "timeout": 5
      }
    ],
    "postToolUse": [
      { "command": "${CLAUDE_PLUGIN_ROOT}/hooks/checkpoint.sh" }
    ],
    "afterFileEdit": [
      { "command": "${CLAUDE_PLUGIN_ROOT}/hooks/checkpoint.sh" }
    ],
    "postToolUseFailure": [
      { "command": "${CLAUDE_PLUGIN_ROOT}/hooks/failure-recorder.sh" }
    ],
    "beforeShellExecution": [
      {
        "command": "${CLAUDE_PLUGIN_ROOT}/hooks/shell-guard.sh",
        "matcher": "rm -rf|DROP TABLE|kubectl delete|git push --force|:>\\s",
        "failClosed": true
      }
    ],
    "stop": [
      { "command": "${CLAUDE_PLUGIN_ROOT}/hooks/auto-refine.sh", "loop_limit": 3 }
    ]
  }
}
